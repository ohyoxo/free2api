69: function parseRoomJson(html) {
70:     if (!html) return null;
71:     var htmlStr = String(html);
72:     var idx = htmlStr.indexOf("HNF_GLOBAL_INIT");
73:     if (idx < 0) return null;
74:     var startIdx = htmlStr.indexOf("=", idx) + 1;
75:     var jsonText = htmlStr.substring(startIdx).trim();
76:     var endIdx = jsonText.indexOf("</script>");
77:     if (endIdx > 0) {
78:         jsonText = jsonText.substring(0, endIdx).trim();
79:     }
80:     jsonText = jsonText.replace(/^;?\s*/, "").replace(/\s*;\s*$/, "");
81:     jsonText = jsonText.replace(/function[^}]*?\{[\s\S]*?\}/g, '""');
82:     jsonText = jsonText.replace(/(,?)\w+:\s*function\([^)]*\)\s*\{[^}]*\}/g, "$1$2");
83:     try {
84:         return JSON.parse(jsonText);
85:     } catch (pe) {
86:         return null;
87:     }
88: }
