215: async function loadDetail(link) {
216:     var videoId = "";
217:     if (typeof link === "string") {
218:         var match = link.match(/huya_detail:(.+)/);
219:         videoId = match ? match[1] : link;
220:     }
221:     if (!videoId) return null;
222:     var url = "https://m.huya.com/" + videoId;
223:     try {
224:         var res = await Widget.http.get(url, {
225:             headers: { 
226:                 "User-Agent": MOBILE_UA,
227:                 "Accept": "text/html,application/xhtml+xml"
228:             },
229:             timeout: 15000
230:         });
231:         var html = res.data || res;
232:         if (!html) {
233:             console.error("[Huya] 空响应");
