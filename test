async function loadCategories(params = {}) {
    var url = DEFAULT_HOST + "/zh/categorys";
    var html = await fetchHtml(url);
    if (!html) return [];
    
    var $ = parseHtml(html);
    if (!$) return [];
    
    var items = [];
    $(".categorys .child").each(function() {
        var child = $(this);
        var linkEl = child.find("a");
        var href = linkEl.attr("href");
        if (!href) return;
        
        var urlObj = new URL(href, DEFAULT_HOST);
        var pathParts = urlObj.pathname.split("/");
        var tagId = (pathParts[2] || "") + "/" + (pathParts[3] || "");
        
        var text = cleanText(child.text()).split("(");
        var tagName = text[0];
        var count = text[1] ? parseInt(text[1]) : 0;
        
        items.push({
            id: tagId,
            type: "url",
            mediaType: "movie",
            title: tagName,
            posterPath: "https://via.placeholder.com/200x200?text=" + encodeURIComponent(tagName),
            description: count + " 部影片",
            link: "supjax_tag:" + tagId
        });
    });
    
    return items;
}
 
