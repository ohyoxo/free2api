123: async function fetchLiveList(gameId, page) {
124:     var url = "https://www.huya.com/cache.php?m=LiveList&do=getLiveListByPage&tagAll=0&gameId=" + 
125:               encodeURIComponent(gameId) + "&page=" + page;
126:     var text = await request(url);
127:     var rs = parseResponse(text);
128:     var dataList = (rs && rs.data && rs.data.datas) || [];
129:     var items = [];
130:     for (var i = 0; i < dataList.length; i++) {
131:         var item = dataList[i];
132:         items.push({
133:             id: String(item.profileRoom || ""),
134:             type: "url",
135:             mediaType: "tv",
136:             title: cleanText(item.introduction || item.roomName || ""),
137:             posterPath: cleanText(item.screenshot || ""),
138:             backdropPath: cleanText(item.screenshot || ""),
139:             description: cleanText(item.nick || ""),
140:             link: "huya_detail:" + (item.profileRoom || "")
141:         });
142:     }
143:     return {
144:         items: items,
145:         page: page,
146:         totalPage: (rs && rs.data) ? rs.data.totalPage : 1,
147:         totalCount: (rs && rs.data) ? rs.data.totalCount : items.length
148:     };
149: }
