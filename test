function cleanText(text) {
    return String(text || "").trim();
}
 
async function request(url) {
    try {
        var res = await Widget.http.get(url, {
            headers: {
                "User-Agent": MOBILE_UA,
                "Accept": "application/json, text/plain, */*"
            },
            timeout: 15000
        });
        return res.data || res;
    } catch (e) {
        console.error("[Huya] 请求失败:", url, e.message);
        return null;
    }
}
 
function parseResponse(text) {
    if (!text) return null;
    try {
        return JSON.parse(text);
    } catch (e) {
        console.error("[Huya] JSON 解析失败:", e.message);
        return null;
    }
}
 
async function fetchLiveList(gameId, page) {
    var url = "https://www.huya.com/cache.php?m=LiveList&do=getLiveListByPage&tagAll=0&gameId=" + 
              encodeURIComponent(gameId) + "&page=" + page;
    
    var text = await request(url);
    var rs = parseResponse(text);
    var dataList = (rs && rs.data && rs.data.datas) || [];
    
    var items = [];
    for (var i = 0; i < dataList.length; i++) {
        var item = dataList[i];
        items.push({
            id: String(item.profileRoom || ""),
            type: "url",
            mediaType: "tv",
            title: cleanText(item.introduction || item.roomName || ""),
            posterPath: cleanText(item.screenshot || ""),
            backdropPath: cleanText(item.screenshot || ""),
            description: cleanText(item.nick || ""),
            link: "huya_detail:" + (item.profileRoom || "")
        });
    }
    
    return {
        items: items,
        page: page,
        totalPage: (rs && rs.data) ? rs.data.totalPage : 1,
        totalCount: (rs && rs.data) ? rs.data.totalCount : items.length
    };
}
 
