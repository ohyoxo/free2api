69: function parseRoomJson(html) {
70:     if (!html) return null;
71:     var htmlStr = String(html);
72:     var idx = htmlStr.indexOf("HNF_GLOBAL_INIT");
73:     if (idx < 0) {
74:         console.error("[Huya] 未找到 HNF_GLOBAL_INIT");
75:         return null;
76:     }
77:     var startIdx = htmlStr.indexOf("=", idx) + 1;
78:     var jsonText = htmlStr.substring(startIdx).trim();
79:     var endIdx = jsonText.indexOf("</script>");
80:     if (endIdx > 0) {
81:         jsonText = jsonText.substring(0, endIdx).trim();
82:     }
83:     jsonText = jsonText
84:         .replace(/^;?\s*/, "")
85:         .replace(/\s*;\s*$/, "");
86:     jsonText = jsonText
87:         .replace(/function[^}]*?\{[\s\S]*?\}/g, '""')
88:         .replace(/(,?)\w+:\s*function\([^)]*\)\s*\{[^}]*\}/g, '$1$2');
89:     try {
90:         return JSON.parse(jsonText);
91:     } catch (pe) {
92:         console.error("[Huya] JSON 解析失败:", pe.message);
93:         console.error("[Huya] JSON 前 100 字符:", jsonText.substring(0, 100));
94:         return null;
95:     }
96: }
