204:             type: "url",
205:             mediaType: "tv",
206:             title: cleanText(item.game_nick || item.game_introduction || ""),
207:             posterPath: cleanText(item.game_screenshot || item.game_avatarUrl180 || ""),
208:             description: isLive ? "直播中" : "未开播",
209:             link: "huya_detail:" + (item.room_id || "")
210:         });
211:     }
212:     return items;
213: }
