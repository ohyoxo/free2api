245: async function loadPlayLink(link) {
246:     var match = link.match(/huya_play:([^:]+):(\d+)/);
247:     if (!match) return null;
248:     var videoId = match[1];
249:     var bitRate = parseInt(match[2]);
250:     var url = "https://m.huya.com/" + videoId;
251:     try {
252:         var res = await Widget.http.get(url, {
253:             headers: {
254:                 "User-Agent": MOBILE_UA,
255:                 "Accept": "text/html"
256:             },
257:             timeout: 15000
258:         });
259:         var html = res.data || res;
260:         var jsonObj = parseRoomJson(html);
261:         if (!jsonObj) return null;
262:         var roomInfo = jsonObj.roomInfo || {};
263:         var tLiveInfo = roomInfo.tLiveInfo || {};
264:         var streamList = (tLiveInfo && tLiveInfo.tLiveStreamInfo && tLiveInfo.tLiveStreamInfo.vStreamInfo && tLiveInfo.tLiveStreamInfo.vStreamInfo.value) || [];
265:         if (streamList.length === 0) return null;
266:         var line = streamList[0];
267:         var sFlvUrl = line.sFlvUrl || "";
268:         var sHlsUrl = line.sHlsUrl || "";
269:         var sStreamName = line.sStreamName || "";
270:         var sFlvAntiCode = line.sFlvAntiCode || "";
271:         var sHlsAntiCode = line.sHlsAntiCode || "";
272:         if (!sStreamName) return null;
273:         var strFlv = sFlvUrl || sHlsUrl;
274:         var strHls = sHlsUrl || sFlvUrl;
275:         var flvUrl = strFlv + "/" + sStreamName + ".flv?" + (sFlvAntiCode || sHlsAntiCode);
276:         var hlsUrl = strHls + "/" + sStreamName + ".m3u8?" + (sHlsAntiCode || sFlvAntiCode);
277:         if (bitRate > 0) {
278:             flvUrl += "&ratio=" + bitRate;
279:             hlsUrl += "&ratio=" + bitRate;
280:         }
281:         hlsUrl = hlsUrl.replace(/^http:\/\//, "https://");
282:         flvUrl = flvUrl.replace(/^http:\/\//, "https://");
283:         return {
284:             id: "huya_play_" + videoId + "_" + bitRate,
285:             type: "url",
286:             videoUrl: hlsUrl,
287:             playerType: "app"
288:         };
289:     } catch (e) {
290:         return null;
291:     }
292: }
