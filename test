238:             console.error("[Huya] 解析失败");
239:             return null;
240:         }
241:         var roomInfo = jsonObj.roomInfo || {};
242:         var roomProfile = jsonObj.roomProfile || {};
243:         var tLiveInfo = roomInfo.tLiveInfo || {};
244:         var tProfileInfo = roomInfo.tProfileInfo || roomProfile.tProfileInfo || {};
245:         var title = cleanText(tLiveInfo.sRoomName || tLiveInfo.sIntroduction || tProfileInfo.sNick || "");
246:         var episodeItems = [];
247:         var streamList = (tLiveInfo.tLiveStreamInfo?.vStreamInfo?.value) || [];
248:         if (streamList.length > 0) {
249:             var bitrates = [
250:                 { name: "原画", bitRate: 0 },
251:                 { name: "高清", bitRate: 2000 },
252:                 { name: "流畅", bitRate: 500 }
253:             ];
254:             for (var i = 0; i < bitrates.length; i++) {
255:                 episodeItems.push({
256:                     id: "huya_play_" + videoId + "_" + bitrates[i].bitRate,
257:                     type: "url",
258:                     title: bitrates[i].name + " - " + title,
259:                     link: "huya_play:" + videoId + ":" + bitrates[i].bitRate
260:                 });
261:             }
262:         }
263:         return {
264:             id: "huya_" + videoId,
265:             type: "url",
266:             mediaType: "tv",
267:             title: title || "直播间 " + videoId,
268:             description: cleanText(tLiveInfo.sIntroduction || ""),
269:             posterPath: cleanText(tLiveInfo.sScreenshot || tLiveInfo.sCoverUrl || tProfileInfo.sAvatar180 || ""),
270:             backdropPath: cleanText(tLiveInfo.sScreenshot || tLiveInfo.sCoverUrl || ""),
271:             backdropPaths: [cleanText(tLiveInfo.sScreenshot || tLiveInfo.sCoverUrl || "")],
272:             episodeItems: episodeItems,
273:             genreItems: [],
274:             link: link
275:         };
276:     } catch (e) {
277:         console.error("[Huya] loadDetail 失败:", e.message);
278:         return null;
279:     }
280: }
