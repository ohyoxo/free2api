185: async function search(params = {}) {
186:     var keyword = (params.keyword || "").trim();
187:     var page = params.page || 1;
188:     var pagesize = 20;
189:     if (!keyword) return [];
190:     var paramsStr = "m=Search&do=getSearchContent&q=" + encodeURIComponent(keyword) +
191:                     "&uid=0&v=4&typ=-5&livestate=0&rows=" + pagesize +
192:                     "&start=" + ((page - 1) * pagesize);
193:     var url = "https://search.cdn.huya.com/?" + paramsStr;
194:     var text = await request(url);
195:     var result = parseResponse(text);
196:     var items = [];
197:     var section = (result && result.response && result.response["1"]) || {};
198:     var docs = section.docs || [];
199:     for (var i = 0; i < docs.length; i++) {
200:         var item = docs[i];
201:         var isLive = item.gameLiveOn === true || item.gameLiveOn === "true";
202:         items.push({
