function formatImgUrl(url) {
    if (!url) return "";
    if (url.startsWith("//")) {
        url = "https:" + url;
    }
    return url;
}
 
function cleanText(text) {
    return String(text || "").trim();
}
 
async function fetchHtml(url) {
    try {
        var res = await Widget.http.get(url, {
            headers: {
                "User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/127.0.0.0 Safari/537.36",
                "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
                "Accept-Language": "zh-CN,zh;q=0.9,en;q=0.8"
            },
            timeout: 15000
        });
        return res.data || res;
    } catch (e) {
        console.error("[Supjax] 请求失败:", url, e.message);
        return null;
    }
}
 
function parseHtml(html) {
    if (!html) return null;
    return Widget.html.load(html);
}
 
async function loadPopular(params = {}) {
    var timeRange = params.time || "";
    var page = params.page || 1;
    var url = DEFAULT_HOST + "/popular/" + timeRange + "/page/" + page;
    
    var html = await fetchHtml(url);
    if (!html) return [];
    
    var $ = parseHtml(html);
    if (!$) return [];
    
    var items = [];
    $(".post").each(function() {
        var item = $(this);
        var linkEl = item.find(".img");
        var href = linkEl.attr("href");
        if (!href) return;
        
        var urlObj = new URL(href, DEFAULT_HOST);
        var pathParts = urlObj.pathname.split("/");
        var videoId = pathParts[2];
        
        items.push({
            id: videoId,
            type: "url",
            mediaType: "movie",
            title: cleanText(linkEl.attr("title")),
            posterPath: formatImgUrl(item.find("img").data("original")),
            backdropPath: formatImgUrl(item.find("img").data("original")),
            description: cleanText(item.find(".meta").text()),
            link: "supjax_detail:" + videoId
        });
    });
    
    return items;
}
 
