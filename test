async function loadDetail(link) {
    var videoId = "";
    if (typeof link === "string") {
        var match = link.match(/supjax_detail:(.+)/);
        videoId = match ? match[1] : link;
    }
    
    if (!videoId) return null;
    
    var url = DEFAULT_HOST + "/zh/" + videoId;
    var html = await fetchHtml(url);
    if (!html) return null;
    
    var $ = parseHtml(html);
    if (!$) return null;
    
    var vodContent = cleanText($(".post-meta .img").attr("alt"));
    var vodName = vodContent.replace("[无码破解]", "").trim();
    var match = vodContent.match(/^[\w|-]+/);
    if (match) {
        vodName = match[0];
    }
    
    var episodeItems = [];
    $(".video-wrap .btn-server").each(function(i) {
        var btn = $(this);
        var serverName = cleanText(btn.text());
        episodeItems.push({
            id: videoId + "_" + i,
            type: "url",
            title: serverName + " - " + vodName,
            link: "supjax_play:" + videoId + ":" + i
        });
    });
    
    var tags = [];
    $(".post-meta .tags a").each(function() {
        var tagName = cleanText($(this).text());
        if (tagName) {
            tags.push({ id: tagName, title: "#" + tagName });
        }
    });
    
    var categories = [];
    $(".post-meta .cats a").each(function() {
        var catName = cleanText($(this).text());
        if (catName) {
            categories.push({ id: catName, title: catName });
        }
    });
    
    return {
        id: "supjax_" + videoId,
        type: "url",
        mediaType: "movie",
        title: vodName,
        description: vodContent,
        posterPath: formatImgUrl($(".post-meta .img").attr("src")),
        backdropPath: formatImgUrl($(".post-meta .img").attr("src")),
        backdropPaths: [formatImgUrl($(".post-meta .img").attr("src"))],
        genreItems: tags.concat(categories),
        episodeItems: episodeItems,
        link: link
    };
}
 
async function loadPlayLink(link) {
    var match = link.match(/supjax_play:([^:]+):(\d+)/);
    if (!match) return null;
    
    var videoId = match[1];
    var serverIndex = parseInt(match[2]);
    
    return {
        id: "supjax_play_" + videoId + "_" + serverIndex,
        type: "url",
        videoUrl: DEFAULT_HOST + "/zh/" + videoId + "?server=" + serverIndex,
        playerType: "app"
    };
}
