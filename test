282: async function loadPlayLink(link) {
283:     var match = link.match(/huya_play:([^:]+):(\d+)/);
284:     if (!match) return null;
285:     var videoId = match[1];
286:     var bitRate = parseInt(match[2]);
287:     var url = "https://m.huya.com/" + videoId;
288:     try {
289:         var res = await Widget.http.get(url, {
290:             headers: { "User-Agent": MOBILE_UA, "Accept": "text/html" },
291:             timeout: 15000
292:         });
293:         var html = res.data || res;
294:         var jsonObj = parseRoomJson(html);
295:         if (!jsonObj) return null;
296:         var roomInfo = jsonObj.roomInfo || {};
297:         var tLiveInfo = roomInfo.tLiveInfo || {};
298:         var streamList = (tLiveInfo.tLiveStreamInfo?.vStreamInfo?.value) || [];
299:         if (streamList.length === 0) return null;
300:         var line = streamList[0];
301:         var sFlvUrl = line.sFlvUrl || "";
302:         var sHlsUrl = line.sHlsUrl || "";
303:         var sStreamName = line.sStreamName || "";
304:         var sFlvAntiCode = line.sFlvAntiCode || "";
305:         var sHlsAntiCode = line.sHlsAntiCode || "";
306:         if (!sStreamName) return null;
307:         var strFlv = sFlvUrl || sHlsUrl;
308:         var strHls = sHlsUrl || sFlvUrl;
309:         var flvUrl = strFlv + "/" + sStreamName + ".flv?" + (sFlvAntiCode || sHlsAntiCode);
310:         var hlsUrl = strHls + "/" + sStreamName + ".m3u8?" + (sHlsAntiCode || sFlvAntiCode);
311:         if (bitRate > 0) {
312:             flvUrl += "&ratio=" + bitRate;
313:             hlsUrl += "&ratio=" + bitRate;
314:         }
315:         hlsUrl = hlsUrl.replace(/^http:\/\//, "https://");
316:         flvUrl = flvUrl.replace(/^http:\/\//, "https://");
317:         return {
318:             id: "huya_play_" + videoId + "_" + bitRate,
319:             type: "url",
320:             videoUrl: hlsUrl,
321:             playerType: "app"
322:         };
323:     } catch (e) {
324:         console.error("[Huya] loadPlayLink 失败:", e.message);
325:         return null;
326:     }
327: }
